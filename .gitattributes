# Normalize text files to LF in the repository.
* text=auto

# HDL / scripts / docs
*.m text eol=lf
*.v text eol=lf
*.sv text eol=lf
*.vh text eol=lf
*.xdc text eol=lf
*.tcl text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary artifacts
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.docx binary
*.zip binary
